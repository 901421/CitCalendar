# URL de conexión a la base de datos PostgreSQL (local o Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/citcalendar?schema=public"

# Configuración del Servidor
PORT=3001

# Autenticación
JWT_SECRET="super_secret_jwt_key_change_me_in_production"
JWT_EXPIRES_IN="7d"

# Stripe (Fase 2)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Configuración de Correo Electrónico (Nodemailer)
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your_mailtrap_user"
EMAIL_PASS="your_mailtrap_password"
EMAIL_FROM="no-reply@citcalendar.com"
